generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Client {
  id              String   @id @default(uuid())
  excelClientName String   @unique
  displayName     String   @unique
  companyName     String
  toEmails        String
  ccEmails        String
  bccEmails       String
  subject         String
  bodyTemplate    String
  sendReport      Boolean  @default(true)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
